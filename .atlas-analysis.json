  "keyFeatures": [
    "Interactive CLI menu with 18 built-in attack and scanning options",
    "Wireless monitor mode management via airmon-ng",
    "WPA/WPA2 handshake capture and cracking with aircrack-ng",
    "WPS brute-force attacks using Reaver",
    "Custom wordlist generation with Crunch",
    "Network scanning with Nmap",
